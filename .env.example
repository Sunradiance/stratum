# ===========================================
# Stratum — plug in 3 APIs and go
# ===========================================
# cp .env.example .env
# Then: npm run setup && npm run dev
# Open http://localhost:8791
# ===========================================

# ----- 1. LLM (required for AI features) -----
# Groq free tier works great: https://console.groq.com/
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=qwen/qwen3-32b

# ----- 2. Tavily (web signal scanning) -----
# Free tier: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ----- 3. Serper (supplementary Google search) -----
# Free tier: https://serper.dev/
SERPER_API_KEY=your_serper_api_key_here

# ----- Server (optional) -----
STRATUM_HOST=0.0.0.0
STRATUM_PORT=8791
FLASK_DEBUG=True